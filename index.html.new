<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Financial Manager</title>
    <style>
      :root { --bg:#f4f7fb; --card:#ffffff; --border:#dfe8f2; --text:#16212c; --muted:#6b7a8f; --accent:#1f6feb; --danger:#ef4444; }
      * { box-sizing: border-box; }
      body { margin:0; font-family:Segoe UI, Roboto, Arial, sans-serif; background:linear-gradient(135deg,#eef4ff 0%, var(--bg) 100%); color:var(--text); }
      .app-shell { max-width:1200px; margin:0 auto; padding:24px 16px 40px; }
      .hero { background:linear-gradient(120deg,#164d9b 0%,#2f7cf1 100%); color:white; padding:22px 24px; border-radius:22px; box-shadow:0 18px 40px rgba(31,111,235,0.2); margin-bottom:20px; }
      .hero h1 { margin:0 0 6px; font-size:28px; }
      .hero p { margin:0; opacity:0.95; }
      .summary-grid { display:grid; grid-template-columns:repeat(4, minmax(0, 1fr)); gap:14px; margin-bottom:18px; }
      .card { background:var(--card); border:1px solid var(--border); border-radius:18px; padding:16px; box-shadow:0 8px 25px rgba(15,23,42,0.06); }
      .card h2, .card h3 { margin:0 0 12px; font-size:18px; }
      .stat-label { font-size:13px; color:var(--muted); margin-bottom:4px; }
      .stat-value { font-size:22px; font-weight:700; }
      .grid { display:grid; gap:16px; }
      .grid-2 { grid-template-columns:repeat(2, minmax(0, 1fr)); }
      .form-row { display:grid; gap:10px; grid-template-columns:repeat(2, minmax(0, 1fr)); margin-bottom:10px; }
      .field { display:flex; flex-direction:column; gap:6px; }
      .field label { font-size:13px; font-weight:600; color:var(--muted); }
      .field input, .field select, .field textarea { border:1px solid var(--border); border-radius:12px; padding:10px 12px; font-size:14px; background:#fbfdff; }
      .field textarea { min-height:80px; resize:vertical; }
      .btn { border:none; border-radius:12px; padding:10px 14px; cursor:pointer; font-weight:600; background:var(--accent); color:white; }
      .btn.secondary { background:#eaf2ff; color:var(--accent); }
      .btn.danger { background:#fee2e2; color:var(--danger); }
      .list { display:grid; gap:8px; margin-top:10px; }
      .list-item { display:flex; justify-content:space-between; align-items:center; gap:12px; padding:10px 12px; background:#f8fbff; border:1px solid var(--border); border-radius:12px; }
      .list-item strong { display:block; }
      .list-item small { color:var(--muted); }
      .calendar-grid { display:grid; grid-template-columns:repeat(7, minmax(0, 1fr)); gap:6px; margin-top:10px; }
      .day-name { text-align:center; font-size:12px; color:var(--muted); font-weight:700; padding-bottom:4px; }
      .day-cell { min-height:72px; border:1px solid var(--border); border-radius:12px; padding:7px; background:#fcfeff; cursor:pointer; position:relative; }
      .day-cell.blank { background:#f7f9fc; cursor:default; }
      .day-cell.active { border-color:var(--accent); box-shadow:inset 0 0 0 1px var(--accent); }
      .day-cell .date-number { font-weight:700; }
      .day-cell .expense-badge { position:absolute; bottom:8px; right:8px; background:var(--accent); color:white; font-size:11px; padding:2px 6px; border-radius:999px; }
      .drop { display:flex; gap:8px; flex-wrap:wrap; }
      .pill { display:inline-block; padding:4px 8px; border-radius:999px; background:#eef5ff; color:var(--accent); font-size:12px; }
      .muted { color:var(--muted); }
      @media (max-width:900px){ .summary-grid{grid-template-columns:repeat(2,minmax(0,1fr));} .grid-2{grid-template-columns:1fr;} }
      @media (max-width:600px){ .summary-grid{grid-template-columns:1fr;} .form-row{grid-template-columns:1fr;} }
    </style>
  </head>
  <body>
    <div class="app-shell">
      <section class="hero">
        <h1>💰 Financial Manager</h1>
        <p>Track your income, expenses, savings, debts, and monthly plans in one place.</p>
      </section>
      <section class="summary-grid">
        <div class="card"><div class="stat-label">Monthly Income</div><div class="stat-value" id="incomeSummary">₹0</div></div>
        <div class="card"><div class="stat-label">Total Expenses</div><div class="stat-value" id="expenseSummary">₹0</div></div>
        <div class="card"><div class="stat-label">Saved in Accounts</div><div class="stat-value" id="savingsSummary">₹0</div></div>
        <div class="card"><div class="stat-label">Remaining</div><div class="stat-value" id="balanceSummary">₹0</div></div>
      </section>
      <section class="grid grid-2">
        <div class="card"><h2>📥 Monthly Income</h2><div class="field"><label for="incomeInput">Income for this month</label><input id="incomeInput" type="number" /></div><button class="btn" id="saveIncome" type="button">Save Income</button></div>
        <div class="card"><h2>🏦 Savings Tracker</h2><div class="form-row"><div class="field"><label for="savingsPlace">Where it is stored</label><input id="savingsPlace" type="text" /></div><div class="field"><label for="savingsAmount">Amount</label><input id="savingsAmount" type="number" /></div></div><button class="btn" id="saveSavings" type="button">Add Savings</button><div class="list" id="savingsList"></div></div>
      </section>
      <section class="grid grid-2">
        <div class="card"><h2>💸 Expenses</h2><div class="form-row"><div class="field"><label for="expenseDate">Date</label><input id="expenseDate" type="date" /></div><div class="field"><label for="expenseCategory">Category</label><select id="expenseCategory"><option>Food</option><option>Transport</option><option>Utilities</option><option>Entertainment</option><option>Health</option><option>Shopping</option><option>Others</option></select></div></div><div class="form-row"><div class="field"><label for="expenseTitle">What was it for?</label><input id="expenseTitle" type="text" /></div><div class="field"><label for="expenseAmount">Amount</label><input id="expenseAmount" type="number" /></div></div><div class="field" id="expenseNoteWrap" style="display:none;"><label for="expenseNote">Explain this expense</label><textarea id="expenseNote"></textarea></div><button class="btn" id="saveExpense" type="button">Add Expense</button><div class="list" id="expenseList"></div></div>
        <div class="card"><h2>📅 Calendar</h2><div class="calendar-grid" id="calendarGrid"></div><div class="card" style="margin-top:12px;"><h3 id="selectedDateLabel">Selected Day</h3><div class="list" id="selectedDayExpenses"></div></div></div>
      </section>
      <section class="grid grid-2">
        <div class="card"><h2>💳 Money I Owe</h2><div class="form-row"><div class="field"><label for="debtName">Name</label><input id="debtName" type="text" /></div><div class="field"><label for="debtAmount">Amount</label><input id="debtAmount" type="number" /></div></div><div class="field"><label for="debtDate">Expected date to pay back</label><input id="debtDate" type="date" /></div><button class="btn secondary" id="saveDebt" type="button">Add Debt</button><div class="list" id="debtList"></div></div>
        <div class="card"><h2>💵 Money People Owe Me</h2><div class="form-row"><div class="field"><label for="receivableName">Name</label><input id="receivableName" type="text" /></div><div class="field"><label for="receivableAmount">Amount</label><input id="receivableAmount" type="number" /></div></div><div class="field"><label for="receivableDate">Expected date</label><input id="receivableDate" type="date" /></div><button class="btn secondary" id="saveReceivable" type="button">Add Receivable</button><div class="list" id="receivableList"></div></div>
      </section>
    </div>
    <script>
      const STORAGE_KEY = 'financial-manager-v2';
      const state = loadState();
      const els = { incomeSummary: document.getElementById('incomeSummary'), expenseSummary: document.getElementById('expenseSummary'), savingsSummary: document.getElementById('savingsSummary'), balanceSummary: document.getElementById('balanceSummary'), incomeInput: document.getElementById('incomeInput'), saveIncome: document.getElementById('saveIncome'), savingsPlace: document.getElementById('savingsPlace'), savingsAmount: document.getElementById('savingsAmount'), saveSavings: document.getElementById('saveSavings'), savingsList: document.getElementById('savingsList'), expenseDate: document.getElementById('expenseDate'), expenseCategory: document.getElementById('expenseCategory'), expenseTitle: document.getElementById('expenseTitle'), expenseAmount: document.getElementById('expenseAmount'), expenseNoteWrap: document.getElementById('expenseNoteWrap'), expenseNote: document.getElementById('expenseNote'), saveExpense: document.getElementById('saveExpense'), expenseList: document.getElementById('expenseList'), calendarGrid: document.getElementById('calendarGrid'), selectedDateLabel: document.getElementById('selectedDateLabel'), selectedDayExpenses: document.getElementById('selectedDayExpenses'), debtName: document.getElementById('debtName'), debtAmount: document.getElementById('debtAmount'), debtDate: document.getElementById('debtDate'), saveDebt: document.getElementById('saveDebt'), debtList: document.getElementById('debtList'), receivableName: document.getElementById('receivableName'), receivableAmount: document.getElementById('receivableAmount'), receivableDate: document.getElementById('receivableDate'), saveReceivable: document.getElementById('saveReceivable'), receivableList: document.getElementById('receivableList') };
      function loadState(){ const raw = localStorage.getItem(STORAGE_KEY); if(!raw){ const today = new Date(); const key = `${today.getFullYear()}-${String(today.getMonth()+1).padStart(2,'0')}`; return {selectedMonth:key, selectedDate:`${key}-${String(today.getDate()).padStart(2,'0')}`, months:{[key]:{income:0,expenses:[],savings:[],debts:[],receivables:[]}}}; } return JSON.parse(raw); }
      function saveState(){ localStorage.setItem(STORAGE_KEY, JSON.stringify(state)); }
      function getMonthData(){ if(!state.months[state.selectedMonth]) state.months[state.selectedMonth]={income:0,expenses:[],savings:[],debts:[],receivables:[]}; return state.months[state.selectedMonth]; }
      function formatCurrency(v){ return new Intl.NumberFormat('en-IN',{style:'currency',currency:'INR',maximumFractionDigits:0}).format(v||0); }
      function render(){ const monthData=getMonthData(); const expenses=monthData.expenses||[]; const savings=monthData.savings||[]; const debts=monthData.debts||[]; const receivables=monthData.receivables||[]; const expensesTotal=expenses.reduce((s,i)=>s+Number(i.amount||0),0); const savingsTotal=savings.reduce((s,i)=>s+Number(i.amount||0),0); els.incomeSummary.textContent=formatCurrency(monthData.income||0); els.expenseSummary.textContent=formatCurrency(expensesTotal); els.savingsSummary.textContent=formatCurrency(savingsTotal); els.balanceSummary.textContent=formatCurrency((monthData.income||0)-expensesTotal); renderList(els.savingsList,savings, item=>`<div class="list-item"><div><strong>${item.place}</strong><small>${formatCurrency(item.amount)}</small></div><button class="btn danger" data-remove-savings="${item.id}" type="button">Remove</button></div>`); renderList(els.expenseList,expenses, item=>`<div class="list-item"><div><strong>${item.title}</strong><small>${item.date} • ${item.category}${item.note? ' • '+item.note:''}</small></div><div class="drop"><span class="pill">${formatCurrency(item.amount)}</span><button class="btn danger" data-remove-expense="${item.id}" type="button">Remove</button></div></div>`); renderList(els.debtList,debts, item=>`<div class="list-item"><div><strong>${item.name}</strong><small>Pay by ${item.dueDate}</small></div><div class="drop"><span class="pill">${formatCurrency(item.amount)}</span><button class="btn danger" data-remove-debt="${item.id}" type="button">Remove</button></div></div>`); renderList(els.receivableList,receivables, item=>`<div class="list-item"><div><strong>${item.name}</strong><small>Expected ${item.dueDate}</small></div><div class="drop"><span class="pill">${formatCurrency(item.amount)}</span><button class="btn danger" data-remove-receivable="${item.id}" type="button">Remove</button></div></div>`); renderCalendar(expenses); renderSelectedDay(expenses); }
      function renderList(el, items, template){ if(!items.length){ el.innerHTML='<div class="muted">Nothing here yet</div>'; return; } el.innerHTML=items.map(template).join(''); }
      function renderCalendar(expenses){ const [year, month] = state.selectedMonth.split('-').map(Number); const first = new Date(year, month-1, 1); const firstWeekday = first.getDay(); const daysInMonth = new Date(year, month, 0).getDate(); const counts={}; expenses.forEach(item=>{ const [itemYear,itemMonth,itemDay]=item.date.split('-').map(Number); if(itemYear===year && itemMonth===month){ counts[itemDay]=(counts[itemDay]||0)+1; } }); const cells=[]; for(let i=0;i<firstWeekday;i++) cells.push('<div class="day-cell blank"></div>'); for(let day=1;day<=daysInMonth;day++){ const key=`${state.selectedMonth}-${String(day).padStart(2,'0')}`; cells.push(`<div class="day-cell ${state.selectedDate===key?'active':''}" data-select-date="${key}"><div class="date-number">${day}</div>${counts[day]?'<div class="expense-badge">'+counts[day]+'</div>':''}</div>`); } while(cells.length%7!==0) cells.push('<div class="day-cell blank"></div>'); els.calendarGrid.innerHTML=['Sun','Mon','Tue','Wed','Thu','Fri','Sat'].map(name=>`<div class="day-name">${name}</div>`).join('')+cells.join(''); }
      function renderSelectedDay(expenses){ const items=expenses.filter(x=>x.date===state.selectedDate); els.selectedDateLabel.textContent=`Selected Day • ${state.selectedDate}`; renderList(els.selectedDayExpenses, items, item=>`<div class="list-item"><div><strong>${item.title}</strong><small>${item.category}${item.note? ' • '+item.note:''}</small></div><span class="pill">${formatCurrency(item.amount)}</span></div>`); }
      els.saveIncome.addEventListener('click', ()=>{ const monthData=getMonthData(); monthData.income=Number(els.incomeInput.value||0); saveState(); render(); });
      els.saveSavings.addEventListener('click', ()=>{ const monthData=getMonthData(); const place=els.savingsPlace.value.trim(); const amount=Number(els.savingsAmount.value||0); if(!place||!amount) return; monthData.savings.push({id:Date.now().toString(),place,amount}); els.savingsPlace.value=''; els.savingsAmount.value=''; saveState(); render(); });
      els.saveExpense.addEventListener('click', ()=>{ const monthData=getMonthData(); const title=els.expenseTitle.value.trim(); const amount=Number(els.expenseAmount.value||0); const date=els.expenseDate.value||state.selectedDate||`${state.selectedMonth}-01`; const note=els.expenseNote.value.trim(); if(!title||!amount) return; monthData.expenses.push({id:Date.now().toString(),title,amount,date,category:els.expenseCategory.value,note}); els.expenseTitle.value=''; els.expenseAmount.value=''; els.expenseNote.value=''; state.selectedDate=date; saveState(); render(); });
      els.saveDebt.addEventListener('click', ()=>{ const monthData=getMonthData(); const name=els.debtName.value.trim(); const amount=Number(els.debtAmount.value||0); const dueDate=els.debtDate.value; if(!name||!amount||!dueDate) return; monthData.debts.push({id:Date.now().toString(),name,amount,dueDate}); els.debtName.value=''; els.debtAmount.value=''; els.debtDate.value=''; saveState(); render(); });
      els.saveReceivable.addEventListener('click', ()=>{ const monthData=getMonthData(); const name=els.receivableName.value.trim(); const amount=Number(els.receivableAmount.value||0); const dueDate=els.receivableDate.value; if(!name||!amount||!dueDate) return; monthData.receivables.push({id:Date.now().toString(),name,amount,dueDate}); els.receivableName.value=''; els.receivableAmount.value=''; els.receivableDate.value=''; saveState(); render(); });
      els.expenseCategory.addEventListener('change', ()=>{ els.expenseNoteWrap.style.display = els.expenseCategory.value==='Others'?'block':'none'; });
      document.addEventListener('click', (e)=>{ const removeSavings=e.target.getAttribute('data-remove-savings'); if(removeSavings){ const monthData=getMonthData(); monthData.savings=monthData.savings.filter(x=>x.id!==removeSavings); saveState(); render(); return; } const removeExpense=e.target.getAttribute('data-remove-expense'); if(removeExpense){ const monthData=getMonthData(); monthData.expenses=monthData.expenses.filter(x=>x.id!==removeExpense); saveState(); render(); return; } const removeDebt=e.target.getAttribute('data-remove-debt'); if(removeDebt){ const monthData=getMonthData(); monthData.debts=monthData.debts.filter(x=>x.id!==removeDebt); saveState(); render(); return; } const removeReceivable=e.target.getAttribute('data-remove-receivable'); if(removeReceivable){ const monthData=getMonthData(); monthData.receivables=monthData.receivables.filter(x=>x.id!==removeReceivable); saveState(); render(); return; } const selectDate=e.target.closest('[data-select-date]'); if(selectDate){ state.selectedDate=selectDate.getAttribute('data-select-date'); saveState(); render(); } });
      render();
    </script>
  </body>
</html>
